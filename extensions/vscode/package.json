{
  "name": "nexus-ai-vscode",
  "displayName": "Nexus AI",
  "description": "Nexus AI coding assistant for VS Code workspaces.",
  "version": "0.2.1",
  "publisher": "nexus-ai",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onView:nexus-ai.assistant",
    "onView:nexus-ai.explorerAssistant",
    "onView:nexus-ai.workspace",
    "onView:nexus-ai.explorerWorkspace",
    "onCommand:nexus-ai.connect",
    "onCommand:nexus-ai.openAssistant",
    "onCommand:nexus-ai.showWorkspace",
    "onCommand:nexus-ai.refreshWorkspace",
    "onCommand:nexus-ai.askWorkspace",
    "onCommand:nexus-ai.setApiUrl",
    "onCommand:nexus-ai.testApiConnection",
    "onCommand:nexus-ai.setDeveloperToken",
    "onCommand:nexus-ai.ask",
    "onCommand:nexus-ai.askSelection",
    "onCommand:nexus-ai.explainFile"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nexus-ai.connect",
        "title": "Nexus AI: Connect"
      },
      {
        "command": "nexus-ai.openAssistant",
        "title": "Nexus AI: Open Assistant"
      },
      {
        "command": "nexus-ai.showWorkspace",
        "title": "Nexus AI: Show Workspace"
      },
      {
        "command": "nexus-ai.refreshWorkspace",
        "title": "Nexus AI: Refresh Workspace"
      },
      {
        "command": "nexus-ai.askWorkspace",
        "title": "Nexus AI: Ask About Workspace"
      },
      {
        "command": "nexus-ai.setApiUrl",
        "title": "Nexus AI: Set API URL"
      },
      {
        "command": "nexus-ai.testApiConnection",
        "title": "Nexus AI: Test API Connection"
      },
      {
        "command": "nexus-ai.setDeveloperToken",
        "title": "Nexus AI: Set Developer Token"
      },
      {
        "command": "nexus-ai.ask",
        "title": "Nexus AI: Ask"
      },
      {
        "command": "nexus-ai.askSelection",
        "title": "Nexus AI: Ask About Selection"
      },
      {
        "command": "nexus-ai.explainFile",
        "title": "Nexus AI: Explain Current File"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexus-ai",
          "title": "Nexus AI",
          "icon": "resources/nexus-icon.svg"
        }
      ]
    },
    "views": {
      "nexus-ai": [
        {
          "id": "nexus-ai.assistant",
          "name": "Assistant",
          "type": "webview"
        },
        {
          "id": "nexus-ai.workspace",
          "name": "Workspace"
        }
      ],
      "explorer": [
        {
          "id": "nexus-ai.explorerAssistant",
          "name": "Nexus AI Assistant",
          "type": "webview"
        },
        {
          "id": "nexus-ai.explorerWorkspace",
          "name": "Nexus AI Workspace"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "nexus-ai.workspace",
        "contents": "Nexus AI reads the open VS Code folder locally.\n[Refresh Workspace](command:nexus-ai.refreshWorkspace)\n[Ask About Workspace](command:nexus-ai.askWorkspace)"
      },
      {
        "view": "nexus-ai.explorerAssistant",
        "contents": "Chat with Nexus AI and apply proposed code edits from VS Code.\n[Connect Nexus AI](command:nexus-ai.connect)"
      },
      {
        "view": "nexus-ai.explorerWorkspace",
        "contents": "Nexus AI reads the open VS Code folder locally.\n[Refresh Workspace](command:nexus-ai.refreshWorkspace)\n[Ask About Workspace](command:nexus-ai.askWorkspace)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "nexus-ai.showWorkspace"
        },
        {
          "command": "nexus-ai.openAssistant"
        },
        {
          "command": "nexus-ai.refreshWorkspace"
        },
        {
          "command": "nexus-ai.askWorkspace"
        }
      ],
      "editor/context": [
        {
          "command": "nexus-ai.ask",
          "group": "navigation@1"
        },
        {
          "command": "nexus-ai.explainFile",
          "group": "navigation@2"
        }
      ],
      "view/title": [
        {
          "command": "nexus-ai.connect",
          "when": "view == nexus-ai.assistant",
          "group": "navigation"
        },
        {
          "command": "nexus-ai.refreshWorkspace",
          "when": "view == nexus-ai.workspace || view == nexus-ai.explorerWorkspace || view == nexus-ai.assistant",
          "group": "navigation"
        },
        {
          "command": "nexus-ai.askWorkspace",
          "when": "view == nexus-ai.workspace || view == nexus-ai.explorerWorkspace",
          "group": "navigation"
        },
        {
          "command": "nexus-ai.testApiConnection",
          "when": "view == nexus-ai.assistant",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Nexus AI",
      "properties": {
        "nexusAi.apiUrl": {
          "type": "string",
          "default": "https://nexus-ai-jet-kappa.vercel.app",
          "description": "Base URL for your deployed Nexus AI app. Use http://localhost:3000 only while running local development."
        },
        "nexusAi.includeWorkspaceContext": {
          "type": "boolean",
          "default": true,
          "description": "Include a bounded workspace snapshot with Nexus AI code requests."
        },
        "nexusAi.workspaceMaxFiles": {
          "type": "number",
          "default": 120,
          "minimum": 20,
          "maximum": 500,
          "description": "Maximum number of workspace files to list for context."
        },
        "nexusAi.workspaceContextMaxChars": {
          "type": "number",
          "default": 32000,
          "minimum": 8000,
          "maximum": 80000,
          "description": "Maximum number of characters of workspace context sent with a request."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "pnpm compile",
    "package": "vsce package --allow-missing-repository --out nexus-ai-vscode.vsix",
    "install:local": "pnpm package && code --install-extension nexus-ai-vscode.vsix --force"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "1.94.0",
    "typescript": "^5.0.0"
  }
}
