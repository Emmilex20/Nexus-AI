{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Nexus AI VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode"
      ],
      "outFiles": ["${workspaceFolder}/extensions/vscode/dist/**/*.js"],
      "preLaunchTask": "Compile Nexus AI VS Code Extension"
    }
  ]
}
